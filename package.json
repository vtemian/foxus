{
  "name": "foxus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "tauri": {
    "appPath": "src/tauri"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "cd src/web && vitest run",
    "test:watch": "cd src/web && vitest",
    "type-check": "tsc --noEmit",
    "format": "cd src/web && npx biome format --write .",
    "lint": "cd src/web && npx biome check . && npx eslint .",
    "lint:biome": "cd src/web && npx biome check .",
    "lint:eslint": "cd src/web && npx eslint .",
    "check": "cd src/web && npx biome check . && npx eslint . && tsc --noEmit && vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.2.0",
    "vitest": "^4.1.2"
  }
}
